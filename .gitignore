lass Pessoa:
    def __init__(self, nome, email, sexo, numero, cpf):
        self.nome = nome
        self.email = email
        self.sexo = sexo
        self.numero = numero
        self.cpf = cpf

    def exibir_dados(self):
        print("Nome:", self.nome)
        print("Email:", self.email)
        print("Sexo:", self.sexo)
        print("Número:", self.numero)
        print("CPF:", self.cpf)
        print("-" * 30)


# Criando dois objetos
pessoa1 = Pessoa(
    "João Silva",
    "joao@gmail.com",
    "Masculino",
    "61999999999",
    "123.456.789-00"
)

pessoa2 = Pessoa(
    "Maria Souza",
    "maria@gmail.com",
    "Feminino",
    "61888888888",
    "987.654.321-00"
)

# Exibindo os dados
pessoa1.exibir_dados()
pessoa2.exibir_dados()
